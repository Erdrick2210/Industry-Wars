[sub_resource type="GDScript" id="GDScript_7lbcs"]
script/source = "extends Control

@onready var v_box_container: VBoxContainer = $VBoxContainer

func _ready() -> void:
	AudioManager.play_music(\"res://assets/audio/music/intro.mp3\")
	set_process(true)

func _process(_delta: float) -> void:
	if v_box_container:
		var window_size := get_viewport_rect().size
		var container_size := v_box_container.size
		
		var left_margin_x := 50.0
		var center_y := (window_size.y - container_size.y) / 2.0
		
		v_box_container.global_position = Vector2(left_margin_x, center_y)


func _on_config_pressed() -> void:
	pass # Replace with function body.


func _on_pressed() -> void:
	pass # Replace with function body.
"

